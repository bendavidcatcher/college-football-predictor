# PostgreSQL connection string, e.g. postgresql://user:password@localhost:5432/cfb_predictor
DATABASE_URL=

# Secret used to sign JWTs — use a long random string in production
JWT_SECRET=

# Note: on macOS, port 5000 is often occupied by AirPlay Receiver (ControlCenter).
# If the server fails to bind, use 5001 and update the client's VITE_API_URL to match.
PORT=5000

CLIENT_URL=http://localhost:5173
