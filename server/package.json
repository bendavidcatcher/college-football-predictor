{
  "name": "cfb-predictor-server",
  "version": "1.0.0",
  "private": true,
  "description": "Express + Prisma API for the College Football Matchup Predictor",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
